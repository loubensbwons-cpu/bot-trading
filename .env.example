# ========================================================
# BOT TRADING CRYPTO - ENVIRONMENT CONFIGURATION TEMPLATE
# ========================================================
# SECURITY: Never commit this file with real values!
# Copy to .env and fill in your actual credentials
# ========================================================

# ========================================================
# FLASK & SECURITY (REQUIRED)
# ========================================================
# Generate strong secret: python -c "import secrets; print(secrets.token_urlsafe(50))"
FLASK_SECRET_KEY=your-super-secret-key-change-this-in-production-min-50-chars-random
ADMIN_PASSWORD=change-this-admin-password-before-production

# ========================================================
# AUTHENTICATION & OAUTH (REQUIRED for signup)
# ========================================================
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ========================================================
# PAYMENT PROCESSING (for PRO features)
# ========================================================
# Get from: https://dashboard.stripe.com/
STRIPE_PUBLIC_KEY=pk_live_your_public_key_or_pk_test_
STRIPE_SECRET_KEY=sk_live_your_secret_key_or_sk_test_

# ========================================================
# AI PROVIDERS (for analysis & signals)
# ========================================================
# DeepSeek - Fast and cheap LLM
# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# ========================================================
# EXCHANGE CONNECTIONS
# ========================================================
# Binance API keys
# Get from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# ========================================================
# EMAIL & NOTIFICATIONS
# ========================================================
# SendGrid for transactional emails
# Get from: https://sendgrid.com/
SEND_GRID_API_KEY=SG.your-sendgrid-key-here
SMTP_SERVER=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@yourdomain.com

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord webhooks (optional)
DISCORD_WEBHOOK_URL=

# ========================================================
# BLOCKCHAIN & ON-CHAIN ANALYSIS
# ========================================================
# Infura for Web3 RPC access
# Get from: https://infura.io/
WEB3_RPC_URL=https://mainnet.infura.io/v3/your-infura-key
ETHERSCAN_API_KEY=your-etherscan-api-key

# ========================================================
# TRADING RISK MANAGEMENT
# ========================================================
RISK_DAILY_STOP_ENABLED=True
RISK_DAILY_STOP_PCT=5.00
RISK_MAX_TRADES_HOUR_ENABLED=True
RISK_MAX_TRADES_PER_HOUR=12
RISK_VOL_FILTER_ENABLED=False
RISK_MAX_VOLATILITY_PCT=12.000
RISK_SPREAD_FILTER_ENABLED=False
RISK_MAX_SPREAD_PCT=1.000
SCAN_PARALLEL_WORKERS=10

# ========================================================
# DEPLOYMENT & ENVIRONMENT
# ========================================================
ENVIRONMENT=development
DEBUG=False

# 3. OAuth 2.0 (Web Application)
# 4. Authorized URIs: http://localhost:5000/api/oauth/google/callback
GOOGLE_CLIENT_ID=votre_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=votre_google_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/oauth/google/callback

# --- EMAIL SMTP (Confirmation d'email) ---
SMTP_SERVER=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=SG.votre_sendgrid_key_ici
EMAIL_FROM=noreply@bot-trading.local

# --- TELEGRAM & DISCORD ALERTS (Optional) ---
TELEGRAM_BOT_TOKEN=votre_telegram_bot_token
TELEGRAM_CHAT_ID=votre_telegram_chat_id
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID

# --- BLOCKCHAIN / ON-CHAIN DATA (Optional) ---
WEB3_RPC_URL=https://mainnet.infura.io/v3/votre_infura_key
ETHERSCAN_API_KEY=votre_etherscan_api_key

# --- AUTRE ---
FLASK_SECRET_KEY=change_this_to_random_string
BOT_MODE=simulation

# --- MODÈLE IA (optionnel, gpt-4o par défaut) ---
# Options recommandées : gpt-4o | gpt-4o-mini (moins cher, moins précis)
OPENAI_MODEL=gpt-4o

